# Sectors Supabase — required for upload to idx_broker_summary_daily
SUPABASE_URL=
SUPABASE_KEY=

# IPOT (IndoPremier) — primary source (curl_cffi WS hybrid)
# Auth is via QR scan, not username/password. To bootstrap:
#   1. python auth_bootstrap.py
#   2. Scan QR with mobile IPOT app
#   3. ipot_creds.json is written (gitignored)
# The daily scrape reads ipot_creds.json and rotates the token on each run.
# When the token expires (likely weeks/months), re-run auth_bootstrap.py.
# For CI: paste ipot_creds.json contents as IPOT_CREDS_JSON GitHub secret.
